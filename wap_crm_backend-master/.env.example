# Application Configuration
NODE_ENV=development
PORT=5000

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/wap_crm?schema=public

# Redis Configuration (BullMQ queues)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Security
JWT_SECRET=supersecretkey_dev
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=supersecretrefreshkey_dev
JWT_REFRESH_EXPIRES_IN=7d

# Logging
LOG_LEVEL=info

# Third-Party External Integrations
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

RESEND_API_KEY=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

META_WHATSAPP_TOKEN=
AICREDITS_API_KEY=
