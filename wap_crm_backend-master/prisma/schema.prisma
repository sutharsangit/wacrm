generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// CORE & MULTI-TENANCY
// -----------------------------------------------------------------------------
model Organization {
  id        String   @id @default(uuid())
  name      String
  industry  String?
  address   String?
  timezone  String   @default("UTC")
  
  logoUrl   String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  users            User[]
  roles            Role[]
  leads            Lead[]
  settings         Setting[]
  subscriptions    Subscription[]
  webhooks         Webhook[]
  conversations    Conversation[]
  broadcasts       BroadcastCampaign[]
  dashboardSnaps   DashboardSnapshot[]
  auditLogs        AuditLog[]
  templates        Template[]
  notifications    Notification[]
}

model User {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  email          String       @unique
  passwordHash   String
  firstName      String
  lastName       String?
  
  roleId         String
  role           Role         @relation(fields: [roleId], references: [id])
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  assignedLeads  LeadAssignment[]
  createdLeads   Lead[]       @relation("CreatedBy")
  followUps      FollowUp[]
  callLogs       CallLog[]
  notes          Note[]
  activities     ActivityLog[]
  notifications  Notification[]
}

model Role {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String // Owner, Admin, Sales Manager, Sales Executive
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  users          User[]
  permissions    Permission[]
}

model Permission {
  id        String   @id @default(uuid())
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  action    String // e.g. "leads:read", "leads:write", "users:manage"
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// LEAD MANAGEMENT & CRM
// -----------------------------------------------------------------------------
model Lead {
  id                  String       @id @default(uuid())
  organizationId      String
  organization        Organization @relation(fields: [organizationId], references: [id])
  
  name                String
  phone               String?
  email               String?
  company             String?
  leadSource          String       // Meta Ads, Google Ads, CSV, Web Form
  campaign            String?
  
  currentStatus       String       @default("New") // New, Contacted, Qualified, Follow-up, Proposal, Won, Lost, Archived
  leadScore           Int          @default(0)
  qualificationStatus String?      // Hot, Warm, Cold
  priority            String       @default("Medium") // High, Medium, Low
  
  createdById         String?
  createdBy           User?        @relation("CreatedBy", fields: [createdById], references: [id])

  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  deletedAt           DateTime?

  assignments         LeadAssignment[]
  tags                LeadTag[]
  notes               Note[]
  callLogs            CallLog[]
  followUps           FollowUp[]
  timelines           LeadTimeline[]
  statusHistory       LeadStatusHistory[]
  qualifications      LeadQualification[]
  scoreHistory        LeadScore[]
  conversations       Conversation[]
}

model LeadAssignment {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  assignedAt DateTime @default(now())
  active     Boolean  @default(true)
}

model LeadTag {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id])
  tag       String
  
  createdAt DateTime @default(now())
}

model LeadTimeline {
  id          String   @id @default(uuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id])
  action      String   // "Created", "Assigned", "Status Changed", "WhatsApp Sent"
  description String?
  
  createdAt   DateTime @default(now())
}

model LeadStatusHistory {
  id         String   @id @default(uuid())
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id])
  fromStatus String?
  toStatus   String
  changedBy  String?  // user id or system
  
  createdAt  DateTime @default(now())
}

model LeadQualification {
  id          String   @id @default(uuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id])
  question    String
  answer      String
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LeadScore {
  id         String   @id @default(uuid())
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id])
  scoreDelta Int
  newScore   Int
  reason     String?
  
  createdAt  DateTime @default(now())
}

// -----------------------------------------------------------------------------
// CRM INTERACTIONS (NOTES, CALLS, FOLLOW-UPS)
// -----------------------------------------------------------------------------
model Note {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model CallLog {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  callDate  DateTime
  duration  Int?     // seconds
  outcome   String   // Connected, Busy, No Answer, etc.
  remarks   String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FollowUp {
  id        String   @id @default(uuid())
  leadId    String
  lead      Lead     @relation(fields: [leadId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  
  dueDate   DateTime
  taskType  String   // Call, Email, Meeting, WhatsApp
  status    String   @default("Pending") // Pending, Completed, Overdue
  notes     String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// WHATSAPP CRM
// -----------------------------------------------------------------------------
model Conversation {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  leadId         String?
  lead           Lead?        @relation(fields: [leadId], references: [id])
  
  whatsappPhone  String
  status         String       @default("Active") // Active, Closed, Bot-Handled
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  messages       Message[]
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  
  sender         String       // "Bot", "User", "Lead"
  receiver       String
  direction      String       // "Inbound", "Outbound"
  messageType    String       // "Text", "Template", "Image"
  content        String
  deliveryStatus String       @default("Sent") // Sent, Delivered, Read, Failed
  
  createdAt      DateTime     @default(now())
}

model Template {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  content        String
  language       String       @default("en")
  status         String       @default("Approved")
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model BroadcastCampaign {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  targetSegment  String?
  status         String       @default("Draft") // Draft, Scheduled, Running, Completed, Failed
  scheduledAt    DateTime?
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// -----------------------------------------------------------------------------
// ANALYTICS & DASHBOARD
// -----------------------------------------------------------------------------
model DashboardSnapshot {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  date           DateTime
  totalLeads     Int
  qualifiedLeads Int
  conversionRate Float
  revenue        Float?
  metricsData    Json         // JSON dump of other metrics
  
  createdAt      DateTime     @default(now())
}

// -----------------------------------------------------------------------------
// BILLING & SUBSCRIPTIONS
// -----------------------------------------------------------------------------
model Subscription {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  plan           String       // Starter, Professional, Enterprise
  status         String       @default("Active")
  billingCycle   String       // Monthly, Yearly
  renewalDate    DateTime
  razorpaySubId  String?
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  invoices       Invoice[]
}

model Invoice {
  id             String       @id @default(uuid())
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])
  
  amount         Float
  status         String       // Paid, Unpaid, Failed
  issuedAt       DateTime     @default(now())
  paidAt         DateTime?
  razorpayInvId  String?
}

// -----------------------------------------------------------------------------
// WEBHOOKS & SETTINGS
// -----------------------------------------------------------------------------
model Webhook {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  source         String       // Meta Ads, Google Ads, Website Forms
  url            String
  secret         String?
  isActive       Boolean      @default(true)
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  logs           WebhookLog[]
}

model WebhookLog {
  id             String       @id @default(uuid())
  webhookId      String
  webhook        Webhook      @relation(fields: [webhookId], references: [id])
  
  payload        Json
  status         String       // Success, Failed
  errorMessage   String?
  
  createdAt      DateTime     @default(now())
}

model Setting {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  key            String
  value          Json
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// -----------------------------------------------------------------------------
// AUDIT & NOTIFICATIONS
// -----------------------------------------------------------------------------
model ActivityLog {
  id             String       @id @default(uuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  
  action         String
  entityType     String
  entityId       String
  details        Json?
  
  createdAt      DateTime     @default(now())
}

model Notification {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  userId         String
  user           User         @relation(fields: [userId], references: [id])
  
  title          String
  message        String
  isRead         Boolean      @default(false)
  type           String       // System, FollowUp, WhatsApp, etc.
  
  createdAt      DateTime     @default(now())
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  
  userId         String?
  action         String
  details        String?
  
  createdAt      DateTime     @default(now())
}
